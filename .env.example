# Demo server config
# Devnet's ZK ElGamal Proof Program now matches solana-zk-sdk = 6.0.1
# (which we use directly via the bypass-mode proofs in configure/transfer).
SOLANA_RPC_URL=https://api.devnet.solana.com
DEMO_PORT=8088
# 2 decimals so 1M UI fits under the u32 BSGS ceiling for available-balance reads
MINT_DECIMALS=2
INITIAL_DEPOSIT_UI=1000000
TRANSFER_AMOUNT_UI=250000

# Solana keypairs (64-byte JSON arrays — matches solana-keygen output format)
# Generate with: solana-keygen new --outfile /tmp/k.json --no-bip39-passphrase --silent && cat /tmp/k.json
PAYER_KEYPAIR=[]
MINT_KEYPAIR=[]
SENDER_KEYPAIR=[]
RECEIVER_KEYPAIR=[]
AUDITOR_KEYPAIR=[]
